{
  "expo": {
    "name": "Flashpark",
    "slug": "flashpark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flashpark",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0540FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flashpark.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Flashpark utilise votre localisation pour trouver des parkings proches de vous.",
        "NSCameraUsageDescription": "Flashpark utilise la caméra pour scanner les QR codes d'accès.",
        "NSBluetoothAlwaysUsageDescription": "Flashpark utilise le Bluetooth pour contrôler les barrières automatiques."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0540FF"
      },
      "package": "com.flashpark.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Flashpark utilise votre localisation pour trouver des parkings proches."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
